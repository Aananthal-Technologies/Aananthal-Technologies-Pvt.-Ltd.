{
  "name": "aa-project",
  "version": "1.0.0",
  "description": "Production-ready Node.js Express Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npm-run-all --parallel dev:server watch:css",
    "build:css": "sass src/public/scss:src/public/css",
